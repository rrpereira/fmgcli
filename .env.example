# End-to-end test environment variables
# Update these with your FortiManager instance details to run e2e tests
 
FMG_E2E_HOST=https://your-fortimanager.example.com
FMG_E2E_TOKEN=your-api-token
FMG_E2E_USER=your-username
FMG_E2E_PASSWORD=your-password
FMG_E2E_ADOM=root
 
# Required for TestE2E_GetAddressByName
FMG_E2E_ADDRESS_NAME=existing-address-name

# Required for TestE2E_GetAddressByMetafield
FMG_E2E_ADDRESS_METAFIELD_KEY=existing-address-metafield-key
FMG_E2E_ADDRESS_METAFIELD_VALUE=existing-address-metafield-value

# Required for TestE2E_GetAddressesByMetafield
FMG_E2E_ADDRESS_METAFIELD_VALUES=existing-address-metafield-value-1,existing-address-metafield-value-2

# Required for TestE2E_GetAddressByNameIPAndNetmask
FMG_E2E_ADDRESS_NAME_IP_NETMASK_NAME=existing-address-name
FMG_E2E_ADDRESS_NAME_IP_NETMASK_IP=192.168.1.0
FMG_E2E_ADDRESS_NAME_IP_NETMASK_NETMASK=255.255.255.0
 
# Required for TestE2E_GetPolicyByID
FMG_E2E_PKG=existing-package-name
FMG_E2E_POLICY_ID=1
 
# Required for TestE2E_GetPolicyByMetafield
FMG_E2E_POLICY_METAFIELD_KEY=existing-metafield-key
FMG_E2E_POLICY_METAFIELD_VALUE=existing-metafield-value
 
# Required for TestE2E_GetPoliciesByMetafield
FMG_E2E_POLICY_METAFIELD_VALUES=existing-metafield-value-1,existing-metafield-value-2
 
# Required for TestE2E_GetServiceByNamePortAndProtocol
FMG_E2E_SERVICE_NAME=existing-service-name
FMG_E2E_SERVICE_PROTOCOL=tcp
FMG_E2E_SERVICE_MIN_PORT=443
FMG_E2E_SERVICE_MAX_PORT=443